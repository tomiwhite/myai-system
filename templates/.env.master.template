# MASTER .env Template
# Lokalizacja: C:\myai\.env
# 
# To jest MASTER plik ze wszystkimi poufnymi danymi dla CAŁEGO ekosystemu myai.
# Agenci ładują ten plik NAJPIERW, potem D:\myai\.env, potem .env.local
#
# SYNCHRONIZACJA:
# - Źródło prawdy: G:\Mój dysk\podreczne - mysite\myoffice 4-0 dokumentation\.env
# - Sync: C:\myAI_System\scripts\config\sync-env-from-gdrive.ps1
#
# BEZPIECZEŃSTWO:
# - NIGDY nie commitować tego pliku (dodane do .gitignore)
# - Backup codziennie do C:\myAI_System\backups\config-backups\
# - Read-only attribute po synchronizacji

# =============================================================================
# AI MODEL KEYS
# =============================================================================

# OpenAI
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
OPENAI_ORG_ID=org-YOUR_ORG_HERE

# Anthropic
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Azure OpenAI
AZURE_OPENAI_KEY=YOUR_KEY_HERE
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/

# =============================================================================
# CLOUD PROVIDERS
# =============================================================================

# Azure
AZURE_SUBSCRIPTION_ID=YOUR_SUBSCRIPTION_HERE
AZURE_TENANT_ID=YOUR_TENANT_HERE

# AWS
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY_HERE
AWS_DEFAULT_REGION=us-east-1

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\{username}\.gcloud\credentials.json

# =============================================================================
# DATABASES
# =============================================================================

# PostgreSQL
DATABASE_PASSWORD=YOUR_PASSWORD_HERE
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Redis
REDIS_PASSWORD=YOUR_PASSWORD_HERE
REDIS_HOST=localhost
REDIS_PORT=6379

# MongoDB
MONGODB_URI=mongodb://username:password@localhost:27017/

# =============================================================================
# GITHUB & GIT
# =============================================================================

GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE
GITHUB_USERNAME=YOUR_USERNAME

# =============================================================================
# OTHER APIS
# =============================================================================

# Stripe (jeśli używasz płatności)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# SendGrid (jeśli używasz emaili)
SENDGRID_API_KEY=SG.YOUR_KEY_HERE

# =============================================================================
# SECURITY
# =============================================================================

# Secret key dla JWT/session
SECRET_KEY=generate-with-python-secrets-module
JWT_SECRET=generate-with-python-secrets-module

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================

# Sentry (error tracking)
SENTRY_DSN=https://YOUR_KEY@sentry.io/YOUR_PROJECT

# Google Analytics
GA_TRACKING_ID=UA-YOUR_ID_HERE

# =============================================================================
# NOTES
# =============================================================================
# 
# Jak wygenerować SECRET_KEY w Python:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Backup tego pliku:
# C:\myAI_System\backups\config-backups\YYYYMMDD-HHMMSS-.env.master
#
# Rotacja kluczy: Co 90 dni
# Ostatnia rotacja: [DATA]
